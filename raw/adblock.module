#!name=AdBlock
#!desc=去广告模块（头条、番茄、微信、QQ 音乐、京东、美团）

# 广告素材域名（必须拦）
DOMAIN-SUFFIX,byteimg.com,REJECT
DOMAIN-SUFFIX,pstatp.com,REJECT
DOMAIN-KEYWORD,ad-sign,REJECT
DOMAIN-KEYWORD,ad.bytedance,REJECT
DOMAIN-KEYWORD,ad.toutiaoapi,REJECT
DOMAIN-KEYWORD,pangolin,REJECT
DOMAIN-KEYWORD,ad.tiktokv,REJECT

# 奖励广告回调（必须放行）
DOMAIN-SUFFIX,snssdk.com,DIRECT
DOMAIN-KEYWORD,api3-normal-c,DIRECT
DOMAIN-KEYWORD,api5-normal-c,DIRECT
DOMAIN-KEYWORD,reward,DIRECT
DOMAIN-KEYWORD,callback,DIRECT

# 正常功能域名（必须放行）
DOMAIN-SUFFIX,toutiaoapi.com,DIRECT
DOMAIN-SUFFIX,zijieapi.com,DIRECT
DOMAIN-SUFFIX,bytegoofy.com,DIRECT

########## 微信广告 ##########

# 朋友圈广告 CDN
DOMAIN-SUFFIX,pgdt.gtimg.com,REJECT
DOMAIN-SUFFIX,pgdt.gtimg.cn,REJECT
DOMAIN-SUFFIX,pgdt.ugdtimg.com,REJECT

# 公众号底部广告
DOMAIN-SUFFIX,ad.weixin.qq.com,REJECT

# 微信正常功能（必须放行）
DOMAIN-SUFFIX,weixin.qq.com,DIRECT
DOMAIN-SUFFIX,wx.qq.com,DIRECT
DOMAIN-SUFFIX,qq.com,DIRECT

########## QQ 音乐广告 ##########

# 开屏广告
DOMAIN-SUFFIX,ad.tencentmusic.com,REJECT
DOMAIN-SUFFIX,tmead.y.qq.com,REJECT

# 推荐页广告
DOMAIN-KEYWORD,ad.y.qq,REJECT

# 正常功能
DOMAIN-SUFFIX,y.qq.com,DIRECT
DOMAIN-SUFFIX,gtimg.cn,DIRECT

########## 京东广告 ##########

# 开屏广告
DOMAIN-SUFFIX,jdadspro.cn,REJECT
DOMAIN-SUFFIX,jd.com,REJECT,keyword=ad

# 逛逛广告
DOMAIN-KEYWORD,ad.jd,REJECT
DOMAIN-KEYWORD,adsys.jd,REJECT

# 正常功能
DOMAIN-SUFFIX,jd.com,DIRECT
DOMAIN-SUFFIX,jdcdn.com,DIRECT

########## 美团广告 ##########

# 开屏广告
DOMAIN-SUFFIX,ad.meituan.com,REJECT
DOMAIN-SUFFIX,ads.meituan.com,REJECT

# 外卖首页广告
DOMAIN-KEYWORD,adapi.meituan,REJECT
DOMAIN-KEYWORD,ad.meituan,REJECT

# 正常功能
DOMAIN-SUFFIX,meituan.com,DIRECT
DOMAIN-SUFFIX,dianping.com,DIRECT

########## 通用广告拦截 ##########

DOMAIN-KEYWORD,adservice,REJECT
DOMAIN-KEYWORD,adsystem,REJECT
DOMAIN-KEYWORD,adtrack,REJECT
DOMAIN-KEYWORD,adserver,REJECT
DOMAIN-KEYWORD,admob,REJECT
DOMAIN-KEYWORD,advert,REJECT
DOMAIN-KEYWORD,tracking,REJECT
DOMAIN-KEYWORD,log-sdk,REJECT

########## 保底：所有正常域名直连 ##########

DOMAIN-SUFFIX,apple.com,DIRECT
DOMAIN-SUFFIX,icloud.com,DIRECT
DOMAIN-SUFFIX,apps.apple.com,DIRECT
DOMAIN-SUFFIX,googleapis.com,DIRECT
